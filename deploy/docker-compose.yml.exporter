services:
  exporter:
    image: ghcr.io/flben233/lolicon-vps/exporter:latest
    restart: unless-stopped
    ports:
      - "20831:20831"
    networks:
      - v6net
    volumes:
      - type: bind
        source: ./config.json
        target: /app/config.json

networks:
  v6net:  # for ipv6 access
    external: true
