services:
  agent:
    image: ghcr.io/flben233/lolicon-vps/agent:latest
    restart: unless-stopped
    # The agent reports host traffic; host networking avoids container-only NIC stats.
    network_mode: host
    environment:
      INSPECTOR_HOST_ID: "1"
      INSPECTOR_SERVER_URL: "https://vps.lolicon.llc"
      INSPECTOR_NETWORK_IFACE: "eth0"
      HOST_PROC: /host/proc
      HOST_SYS: /host/sys
      HOST_ETC: /host/etc
      TZ: "Asia/Shanghai"
    volumes:
      # gopsutil reads host metrics from these paths when HOST_* is set.
      - type: bind
        source: /proc
        target: /host/proc
        read_only: true
      - type: bind
        source: /sys
        target: /host/sys
        read_only: true
      - type: bind
        source: /etc
        target: /host/etc
        read_only: true
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
