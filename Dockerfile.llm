FROM python:3.11-slim

WORKDIR /app

COPY llm/requirements*.txt ./
RUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || \
    pip install --no-cache-dir fastapi uvicorn openai redis langchain-core langgraph langchain-mcp-adapters pydantic

COPY llm/ ./

EXPOSE 18000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "18000"]
